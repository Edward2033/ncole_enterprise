# ═══════════════════════════════════════════════════════════════════════════════
# N_COLE Interpress — Backend Environment Configuration
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set or the server will refuse to start.
# Variables marked [OPTIONAL] have safe defaults or degrade gracefully if unset.
# Variables marked [PROD-ONLY] are only needed in production deployments.
# Variables marked [DEV-ONLY] are only relevant in local development.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
# [REQUIRED] Runtime environment. Allowed: development | production | test
NODE_ENV=development

# [REQUIRED] Port the API listens on. Default: 4000
PORT=4000

# [OPTIONAL] API route prefix. Default: /api/v1
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] Supabase PostgreSQL connection string.
# For Supabase, use the PgBouncer transaction-mode pooler URL (port 6543) for
# runtime queries. Always include:
#   ?pgbouncer=true&connection_limit=1&pool_timeout=0&sslmode=require
DATABASE_URL="postgresql://<user>:<password>@<pooler-host>:6543/<db>?pgbouncer=true&connection_limit=1&pool_timeout=0&sslmode=require"

# [OPTIONAL] Supabase direct connection (port 5432, no PgBouncer).
# Used only by `prisma migrate dev` and `prisma migrate deploy`.
# If not set, falls back to DATABASE_URL (fine for non-Supabase / single-URL setups).
# Do NOT use the pgbouncer URL for migrations — it will fail.
DIRECT_URL="postgresql://<user>:<password>@<direct-host>:5432/<db>?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Access token secret. Minimum 32 characters. Must be random.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=change_me_min_32_chars_random_hex_string

# [REQUIRED] Refresh token secret. Minimum 32 characters. Must be different from ACCESS_TOKEN_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=change_me_min_32_chars_different_random_hex_string

# [OPTIONAL] Access token lifetime. Default: 15m
ACCESS_TOKEN_EXPIRES_IN=15m

# [OPTIONAL] Refresh token lifetime. Default: 7d
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# [REQUIRED] Comma-separated list of allowed frontend origins.
# In development, include all Vite dev server ports.
# In production, use your real domain names.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# ─── App URL ──────────────────────────────────────────────────────────────────
# [REQUIRED] The public URL of the frontend storefront.
# Used in password reset email links. Must match what users visit in their browser.
# [DEV-ONLY default] http://localhost:5173
# [PROD-ONLY] https://ncoleinterpress.com
APP_URL=http://localhost:5173

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# [OPTIONAL] Google Gemini API key. If not set, AI endpoints return a
# user-friendly "not configured" message instead of HTTP 500.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OPTIONAL] Gemini model to use. Default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# ─── Cloudinary (Image Storage) ───────────────────────────────────────────────
# [OPTIONAL] Required only if using the image upload endpoint (POST /products/upload-image).
# If not set, the upload endpoint returns a 503 with a clear error message.
# Obtain from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MTN MoMo (Mobile Money) ──────────────────────────────────────────────────
# [OPTIONAL] MTN Mobile Money payment gateway credentials.
# Not required for platform to function — customers can use Cash on Delivery.
# Sandbox credentials: https://momodeveloper.mtn.com
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
# [PROD-ONLY] Change to: production
MOMO_TARGET_ENVIRONMENT=sandbox

# ─── Airtel Money ─────────────────────────────────────────────────────────────
# [OPTIONAL] Airtel Money payment gateway credentials.
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
# [PROD-ONLY] Change to: production
AIRTEL_ENVIRONMENT=sandbox

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# [REQUIRED for emails] API key from https://resend.com/api-keys
# Without this, emails are printed to server logs only (no actual delivery).
RESEND_API_KEY=re_your_api_key_here

# [REQUIRED] Sender address shown in all outgoing emails.
# Testing (domain not yet verified): use the Resend sandbox sender:
#   EMAIL_FROM=onboarding@resend.dev
# Production (domain verified in Resend): use your domain with optional display name:
#   EMAIL_FROM="N_COLE Interpress <no-reply@youngdevsofficial.com>"
# This variable is REQUIRED — the server will refuse to start if it is missing.
EMAIL_FROM=onboarding@resend.dev

# [OPTIONAL] Reply-to address shown to recipients.
EMAIL_REPLY_TO=support@youngdevsofficial.com
